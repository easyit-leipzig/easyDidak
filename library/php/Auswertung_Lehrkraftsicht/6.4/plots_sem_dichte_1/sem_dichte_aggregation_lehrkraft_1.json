    "sql": "SELECT\n  kw,\n  AVG(x_kognition) AS avg_x_kognition,\n  MIN(x_kognition) AS min_x_kognition,\n  MAX(x_kognition) AS max_x_kognition,\n  STDDEV_POP(x_kognition) AS std_x_kognition,\n  AVG(x_sozial) AS avg_x_sozial,\n  MIN(x_sozial) AS min_x_sozial,\n  MAX(x_sozial) AS max_x_sozial,\n  STDDEV_POP(x_sozial) AS std_x_sozial,\n  AVG(x_affektiv) AS avg_x_affektiv,\n  MIN(x_affektiv) AS min_x_affektiv,\n  MAX(x_affektiv) AS max_x_affektiv,\n  STDDEV_POP(x_affektiv) AS std_x_affektiv,\n  AVG(x_motivation) AS avg_x_motivation,\n  MIN(x_motivation) AS min_x_motivation,\n  MAX(x_motivation) AS max_x_motivation,\n  STDDEV_POP(x_motivation) AS std_x_motivation,\n  AVG(x_methodik) AS avg_x_methodik,\n  MIN(x_methodik) AS min_x_methodik,\n  MAX(x_methodik) AS max_x_methodik,\n  STDDEV_POP(x_methodik) AS std_x_methodik,\n  AVG(x_performanz) AS avg_x_performanz,\n  MIN(x_performanz) AS min_x_performanz,\n  MAX(x_performanz) AS max_x_performanz,\n  STDDEV_POP(x_performanz) AS std_x_performanz,\n  AVG(x_regulation) AS avg_x_regulation,\n  MIN(x_regulation) AS min_x_regulation,\n  MAX(x_regulation) AS max_x_regulation,\n  STDDEV_POP(x_regulation) AS std_x_regulation,\n  COUNT(*) AS n,\n  AVG(d_semantisch) AS avg_d_semantisch,\n  MIN(d_semantisch) AS min_d_semantisch,\n  MAX(d_semantisch) AS max_d_semantisch,\n  STDDEV_POP(d_semantisch) AS std_d_semantisch,\n  AVG(dominante_dimension_wert) AS avg_dominante_dimension_wert,\n  MIN(dominante_dimension_wert) AS min_dominante_dimension_wert,\n  MAX(dominante_dimension_wert) AS max_dominante_dimension_wert,\n  STDDEV_POP(dominante_dimension_wert) AS std_dominante_dimension_wert,\n  SUM(CASE WHEN polaritaet_gesamt > 0 THEN 1 ELSE 0 END) AS n_pos,\n  SUM(CASE WHEN polaritaet_gesamt < 0 THEN 1 ELSE 0 END) AS n_neg,\n  SUM(CASE WHEN polaritaet_gesamt = 0 THEN 1 ELSE 0 END) AS n_neutral,\n  AVG(CASE WHEN polaritaet_gesamt IS NOT NULL THEN polaritaet_gesamt END) AS avg_polaritaet,\n  SUM(CASE WHEN BINARY dominante_dimension = BINARY 'kognition' THEN 1 ELSE 0 END) AS dom_kognition,\n  SUM(CASE WHEN BINARY dominante_dimension = BINARY 'sozial' THEN 1 ELSE 0 END) AS dom_sozial,\n  SUM(CASE WHEN BINARY dominante_dimension = BINARY 'affektiv' THEN 1 ELSE 0 END) AS dom_affektiv,\n  SUM(CASE WHEN BINARY dominante_dimension = BINARY 'motivation' THEN 1 ELSE 0 END) AS dom_motivation,\n  SUM(CASE WHEN BINARY dominante_dimension = BINARY 'methodik' THEN 1 ELSE 0 END) AS dom_methodik,\n  SUM(CASE WHEN BINARY dominante_dimension = BINARY 'performanz' THEN 1 ELSE 0 END) AS dom_performanz,\n  SUM(CASE WHEN BINARY dominante_dimension = BINARY 'regulation' THEN 1 ELSE 0 END) AS dom_regulation\nFROM datenm_values_sem_dichte_lehrer_type_3\nWHERE datum >= %s AND fach IN (%s, %s) and lehrkraft_id=1 \nGROUP BY kw\nORDER BY kw",
